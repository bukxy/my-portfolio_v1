# Dev uniquement – hot-reload avec Spring Boot DevTools
FROM maven:3.9-eclipse-temurin-21

WORKDIR /app

ENV SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/portfolio

# Cache des dépendances Maven
COPY back/pom.xml .
RUN mvn dependency:go-offline -q

# Le code source est monté via volume dans docker-compose.dev.yml
EXPOSE 8080

CMD ["mvn", "spring-boot:run"]
